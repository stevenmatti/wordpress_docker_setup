# Path to storage
# Folder where docker storage will be at
DEFAULT_PATH=./wp_files

# MySql DB
# Change all these default passwords and usernames
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress

# wordpress
# Change port num if already in use
WP_PORT=8000

# PHP myAdmin
# Change this port if already in use
PHP_PORT=8080

